{
  "name": "product-flow",
  "version": "1.12.6",
  "description": "Product Flow - PM commands for spec-driven development workflow.",
  "author": { "name": "David Valero" },
  "license": "MIT",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/intent-router.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/git-sync.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/permission-request.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/state-notifier.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/security-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/workflow-guard.sh"
          }
        ]
      }
    ]
  },
  "skills": [
    "./skills/start-feature",
    "./skills/start-improvement",
    "./skills/continue",
    "./skills/build",
    "./skills/submit",
    "./skills/fix",
    "./skills/deploy",
    "./skills/status",
    "./skills/context",
    "./skills/inbox-sync",
    "./skills/plan",
    "./skills/tasks",
    "./skills/implement",
    "./skills/checklist",
    "./skills/consolidate-spec",
    "./skills/consolidate-plan",
    "./skills/pr-comments",
    "./skills/speckit.specify",
    "./skills/speckit.specify.improvement",
    "./skills/speckit.plan.improvement",
    "./skills/speckit.clarify",
    "./skills/speckit.plan",
    "./skills/speckit.tasks",
    "./skills/speckit.checklist",
    "./skills/speckit.split",
    "./skills/speckit.retro",
    "./skills/speckit.verify",
    "./skills/speckit.verify-tasks",
    "./skills/speckit.reconcile",
    "./skills/speckit.implement.withTDD",
    "./skills/praxis.complexity-review",
    "./skills/praxis.test-desiderata",
    "./skills/bugmagnet",
    "./skills/praxis.bdd-with-approvals",
    "./skills/praxis.backend-architecture",
    "./skills/praxis.frontend-architecture",
    "./skills/praxis.code-simplifier",
    "./skills/praxis.collaborative-design",
    "./skills/praxis.event-modeling",
    "./skills/praxis.expand-contract"
  ]
}
